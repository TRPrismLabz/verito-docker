# ══════════════════════════════════════════════════════════════
#  Verito v0.1 — Docker Environment Configuration
#  Copy this file: cp .env.example .env
#  Then fill in your real values below.
#
#  NEVER commit .env to git. It is in .gitignore.
# ══════════════════════════════════════════════════════════════

# ── App ──
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
# Generate a real secret: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_STRING

# ── Redis (token map persistence across restarts) ──
REDIS_URL=redis://redis:6379/0
TOKEN_TTL_SECONDS=1800

# ── Nango (OAuth Connection Management) ──
# Sign up at https://nango.dev to get your secret key.
# This lets Verito connect to Gmail, Slack, GitHub on behalf of users.
# Leave blank to use demo mode (built-in sample data, no real OAuth).
NANGO_BASE_URL=https://api.nango.dev
NANGO_SECRET_KEY=

# ── Telegram Bot (Optional — Write Action Approvals) ──
# Create a bot via @BotFather on Telegram.
# Get your chat ID by messaging @userinfobot.
# When set, write actions (send_email etc.) ping you for approval.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
